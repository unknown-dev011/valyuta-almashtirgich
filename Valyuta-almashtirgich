<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Real vaqtda Valyuta Konvertori</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0b2b3b, #1a4a5f, #2c3e50);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: rgba(255, 255, 255, 0.97);
            border-radius: 32px;
            padding: 32px 28px;
            width: 100%;
            max-width: 620px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.3);
        }

        .title {
            text-align: center;
            color: #0f2f3f;
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 28px;
            letter-spacing: -0.3px;
            border-bottom: 3px solid #2c7da0;
            padding-bottom: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #e8f0f5;
            border-radius: 40px;
            padding: 6px 14px;
            font-size: 12px;
            margin-left: 12px;
            font-weight: normal;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #4caf50;
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { opacity: 0.4; transform: scale(0.8); }
            100% { opacity: 1; transform: scale(1.2); }
        }

        .converter-row {
            display: flex;
            gap: 12px;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .amount-box {
            flex: 1.5;
            min-width: 140px;
        }

        .currency-box {
            flex: 1;
            min-width: 110px;
        }

        .result-box {
            flex: 1.5;
            min-width: 140px;
            background: linear-gradient(135deg, #eef5fa, #e0edf5);
            border-radius: 20px;
            padding: 10px 14px;
            text-align: center;
            border: 1px solid #cde3ef;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .amount-input {
            width: 100%;
            padding: 14px 16px;
            border: 2px solid #d4e0e8;
            border-radius: 20px;
            font-size: 18px;
            font-weight: 500;
            outline: none;
            transition: all 0.2s;
            background: white;
        }

        .amount-input:focus {
            border-color: #2c7da0;
            box-shadow: 0 0 0 3px rgba(44,125,160,0.2);
        }

        .currency-select {
            width: 100%;
            padding: 14px 10px;
            border: 2px solid #d4e0e8;
            border-radius: 20px;
            font-size: 15px;
            font-weight: 500;
            background: white;
            cursor: pointer;
            outline: none;
            transition: all 0.2s;
        }

        .result-label-small {
            font-size: 11px;
            font-weight: 600;
            color: #1f5e7e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
        }

        .result-value {
            font-size: 20px;
            font-weight: 800;
            color: #0b2f40;
            word-break: break-word;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        .converted-number {
            background: white;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 18px;
        }

        .target-currency-badge {
            background: #2c7da0;
            color: white;
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 16px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .calculate-btn {
            width: 100%;
            padding: 16px;
            background: #1f6390;
            color: white;
            border: none;
            border-radius: 40px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.25s;
            margin: 12px 0 18px 0;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .calculate-btn:hover {
            background: #0f4a6e;
            transform: translateY(-2px);
        }

        .calculate-btn:active {
            transform: scale(0.97);
        }

        .other-rates {
            margin-top: 20px;
            background: #f8fbfd;
            border-radius: 24px;
            padding: 16px;
            border: 1px solid #dfecf2;
        }

        .other-title {
            font-size: 13px;
            font-weight: 700;
            color: #2c607b;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .rate-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            gap: 10px;
        }

        .rate-item {
            background: white;
            padding: 6px 12px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 500;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
            transition: 0.1s;
        }

        .update-info {
            text-align: center;
            margin-top: 12px;
            font-size: 11px;
            color: #7f9aaa;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        .refresh-btn {
            background: none;
            border: none;
            color: #2c7da0;
            cursor: pointer;
            font-size: 12px;
            text-decoration: underline;
            padding: 4px 8px;
            border-radius: 20px;
        }

        .refresh-btn:hover {
            background: #e0edf5;
        }

        .loading {
            opacity: 0.6;
            pointer-events: none;
        }

        .note {
            text-align: center;
            margin-top: 16px;
            font-size: 11px;
            color: #7f9aaa;
            background: #f8fbfd;
            padding: 8px;
            border-radius: 30px;
        }

        @media (max-width: 550px) {
            .container { padding: 22px 18px; }
            .converter-row { flex-direction: column; align-items: stretch; }
        }
    </style>
</head>
<body>

<div class="container">
    <h1 class="title">
        <span>💱</span> Valyuta Konvertori
        <span class="status-badge" id="statusBadge">
            <span class="status-dot"></span>
            <span id="statusText">Yangi kurs</span>
        </span>
    </h1>

    <div class="converter-row">
        <div class="amount-box">
            <input type="number" class="amount-input" id="amount" placeholder="Miqdor" min="0" step="0.01" value="100">
        </div>
        <div class="currency-box">
            <select class="currency-select" id="currencySelect">
                <option value="USD">🇺🇸 USD</option>
                <option value="EUR">🇪🇺 EUR</option>
                <option value="UZS" selected>🇺🇿 UZS</option>
                <option value="RUB">🇷🇺 RUB</option>
                <option value="GBP">🇬🇧 GBP</option>
                <option value="CNY">🇨🇳 CNY</option>
                <option value="JPY">🇯🇵 JPY</option>
                <option value="KRW">🇰🇷 KRW</option>
                <option value="TRY">🇹🇷 TRY</option>
            </select>
        </div>
        <div class="result-box">
            <div class="result-label-small">⚡ NATIJA (USD)</div>
            <div class="result-value" id="resultDisplay">
                <span class="converted-number" id="convertedValue">0.00</span>
                <span class="target-currency-badge" id="targetCurrencyBadge">🇺🇸 USD</span>
            </div>
        </div>
    </div>

    <button class="calculate-btn" id="convertBtn">
        🔄 Hisoblash
    </button>

    <div class="other-rates">
        <div class="other-title">
            📊 Boshqa valyutalarda (real vaqt kursi)
        </div>
        <div class="rate-grid" id="rateGrid">
            <div style="grid-column:1/-1; text-align:center; padding:8px;">⏳ Kurslar yuklanmoqda...</div>
        </div>
    </div>

    <div class="update-info">
        <span>🕒 <span id="lastUpdate">Kurslar yuklanmoqda...</span></span>
        <button class="refresh-btn" id="manualRefreshBtn">🔄 Yangilash</button>
    </div>

    <p class="note">📈 * Kurslar real vaqtda ExchangeRate-API orqali yangilanadi. Har 10 daqiqada avtomatik yangilanadi.</p>
</div>

<script>
    // ==================== API KALIT ====================
    const API_KEY = 'cur_live_cSQeszwcvJCEjIcL5GLmWSIto8RpXuHq8Squ60BE';
    const BASE_URL = 'https://api.exchangerate-api.com/v4/latest/USD';
    
    // Eslatma: ExchangeRate-API bepul versiyasi uchun kalit kerak emas, lekin siz kalit berdingiz.
    // Agar yuqoridagi API ishlamasa, alternativ: https://api.exchangerate-api.com/v4/latest/USD (kalitsiz)
    // Sizning kalitingiz formatiga qarab, boshqa provider bo'lishi mumkin.
    // Keling ikkala usulni ham qo'llaylik: avval sizning kalitingiz bilan try, keyin fallback.
    
    // ==================== GLOBAL O'ZGARUVCHILAR ====================
    let liveRates = null;          // Real vaqt kurslari saqlanadi
    let lastFetchTime = null;
    let isLoading = false;
    
    // Bayroqlar
    const flagMap = {
        USD: '🇺🇸', EUR: '🇪🇺', UZS: '🇺🇿', RUB: '🇷🇺',
        GBP: '🇬🇧', CNY: '🇨🇳', JPY: '🇯🇵', KRW: '🇰🇷', TRY: '🇹🇷'
    };
    
    const currencies = ['USD', 'EUR', 'UZS', 'RUB', 'GBP', 'CNY', 'JPY', 'KRW', 'TRY'];
    
    // DOM elementlari
    const amountInput = document.getElementById('amount');
    const currencySelect = document.getElementById('currencySelect');
    const convertBtn = document.getElementById('convertBtn');
    const convertedSpan = document.getElementById('convertedValue');
    const targetBadge = document.getElementById('targetCurrencyBadge');
    const rateGrid = document.getElementById('rateGrid');
    const lastUpdateSpan = document.getElementById('lastUpdate');
    const statusTextSpan = document.getElementById('statusText');
    const manualRefreshBtn = document.getElementById('manualRefreshBtn');
    
    // ==================== API ORQALI KURSLARNI YUKLASH ====================
    async function fetchExchangeRates() {
        if (isLoading) return;
        isLoading = true;
        
        statusTextSpan.innerText = 'Yangilanmoqda...';
        
        try {
            // Birinchi urinish: ExchangeRate-API bepul (kalit talab qilmaydi)
            // Sizning kalitingiz boshqa provider uchun bo'lishi mumkin. Ikkalasini ham sinab ko'ramiz.
            let response;
            let data;
            
            // Urinish 1: bepul API (ishonchli)
            try {
                response = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
                if (response.ok) {
                    data = await response.json();
                    if (data && data.rates) {
                        liveRates = data.rates;
                        lastFetchTime = new Date();
                        statusTextSpan.innerText = "✅ Yangi kurs";
                        updateLastUpdateTime();
                        return true;
                    }
                }
            } catch(e) {
                console.log("Bepul API ishlamadi, keyingi urinish...");
            }
            
            // Urinish 2: Sizning kalitingiz bilan (agar kalit exchangeRate-formatda bo'lsa)
            // Ba'zi API-lar: https://api.exchangerate.host/latest?access_key=KEY
            if (API_KEY && API_KEY.length > 10) {
                try {
                    response = await fetch(`https://api.exchangerate.host/latest?access_key=${API_KEY}&base=USD`);
                    if (response.ok) {
                        data = await response.json();
                        if (data && data.rates) {
                            liveRates = data.rates;
                            lastFetchTime = new Date();
                            statusTextSpan.innerText = "✅ API orqali";
                            updateLastUpdateTime();
                            return true;
                        }
                    }
                } catch(e) {}
                
                // Yana bir variant: frankfurter yoki currencyapi
                try {
                    response = await fetch(`https://api.currencyapi.com/v3/latest?apikey=${API_KEY}&base_currency=USD`);
                    if (response.ok) {
                        data = await response.json();
                        if (data && data.data) {
                            // currencyapi formatini o'zgartirish
                            const newRates = {};
                            for (let [key, val] of Object.entries(data.data)) {
                                newRates[key] = val.value;
                            }
                            liveRates = newRates;
                            lastFetchTime = new Date();
                            statusTextSpan.innerText = "✅ CurrencyAPI";
                            updateLastUpdateTime();
                            return true;
                        }
                    }
                } catch(e) {}
            }
            
            // Agar hech qaysi API ishlamasa, fallback statik kurslar
            console.warn("API ishlamadi, statik kurslar ishlatiladi");
            liveRates = {
                USD: 1,
                EUR: 0.92,
                UZS: 12800,
                RUB: 91.5,
                GBP: 0.79,
                CNY: 7.24,
                JPY: 149.5,
                KRW: 1320,
                TRY: 32.1
            };
            lastFetchTime = new Date();
            statusTextSpan.innerText = "⚠️ Offline kurs";
            updateLastUpdateTime();
            return true;
            
        } catch (error) {
            console.error("Kurs yuklashda xatolik:", error);
            statusTextSpan.innerText = "❌ Xatolik";
            return false;
        } finally {
            isLoading = false;
            // Kurslar yuklangandan keyin hisoblashni yangilash
            performFullConversion();
        }
    }
    
    function updateLastUpdateTime() {
        if (lastFetchTime) {
            const timeStr = lastFetchTime.toLocaleTimeString('uz-UZ');
            lastUpdateSpan.innerText = `So‘nggi yangilanish: ${timeStr}`;
            setTimeout(() => {
                if (statusTextSpan.innerText === "✅ Yangi kurs") {
                    statusTextSpan.innerText = "Yangi kurs";
                }
            }, 2000);
        }
    }
    
    // ==================== HISOBLASH (REAL KURSLAR BILAN) ====================
    function performFullConversion() {
        if (!liveRates) {
            // Kurslar hali yuklanmagan
            convertedSpan.textContent = '...';
            targetBadge.innerHTML = `🇺🇸 USD`;
            rateGrid.innerHTML = '<div style="grid-column:1/-1; text-align:center;">⏳ Kurslar yuklanmoqda...</div>';
            return;
        }
        
        let amountVal = parseFloat(amountInput.value);
        if (isNaN(amountVal) || amountVal < 0) {
            amountVal = 0;
            amountInput.value = 0;
        }
        
        const fromCurrency = currencySelect.value;
        
        // Kurslarni tekshirish
        if (!liveRates[fromCurrency] || !liveRates['USD']) {
            convertedSpan.textContent = 'Xato';
            targetBadge.innerHTML = `❓ USD`;
            return;
        }
        
        // USD ga o'tkazish: (amount / fromCurrency kursi) chunki liveRates USD asosida
        // liveRates[fromCurrency] = 1 USD necha fromCurrency? 
        // Masalan: USD->UZS kursi 12800 bo'lsa, 1 USD = 12800 UZS. UZS dan USD ga: amount / 12800
        const amountInUSD = amountVal / liveRates[fromCurrency];
        
        let formattedUSD = amountInUSD.toLocaleString('uz-UZ', { minimumFractionDigits: 2, maximumFractionDigits: 4 });
        convertedSpan.textContent = formattedUSD;
        targetBadge.innerHTML = `🇺🇸 USD`;
        
        // Boshqa valyutalar jadvali
        updateOtherRates(amountVal, fromCurrency);
    }
    
    function updateOtherRates(amount, fromCurrency) {
        if (!liveRates) return;
        
        if (isNaN(amount) || amount < 0) amount = 0;
        const fromRate = liveRates[fromCurrency];
        if (!fromRate) {
            rateGrid.innerHTML = '<div>Kurs topilmadi</div>';
            return;
        }
        
        let itemsHtml = '';
        for (let curr of currencies) {
            if (curr === fromCurrency) continue;
            
            const toRate = liveRates[curr];
            if (!toRate) continue;
            
            const convertedValue = (amount / fromRate) * toRate;
            let displayValue;
            if (Math.abs(convertedValue) > 999999) {
                displayValue = convertedValue.toLocaleString('uz-UZ', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            } else if (Math.abs(convertedValue) < 0.01 && convertedValue !== 0) {
                displayValue = convertedValue.toLocaleString('uz-UZ', { minimumFractionDigits: 4, maximumFractionDigits: 6 });
            } else {
                displayValue = convertedValue.toLocaleString('uz-UZ', { minimumFractionDigits: 2, maximumFractionDigits: 4 });
            }
            
            const flag = flagMap[curr] || '💱';
            itemsHtml += `
                <div class="rate-item">
                    <span>${flag} ${curr}</span>
                    <strong>${displayValue}</strong>
                </div>
            `;
        }
        
        if (itemsHtml === '') {
            itemsHtml = '<div style="grid-column:1/-1; text-align:center;">Maʼlumot yo‘q</div>';
        }
        rateGrid.innerHTML = itemsHtml;
    }
    
    // ==================== AVTOMATIK YANGILANISH ====================
    let autoRefreshInterval = null;
    
    function startAutoRefresh() {
        if (autoRefreshInterval) clearInterval(autoRefreshInterval);
        // Har 10 daqiqada yangilash (600000 ms)
        autoRefreshInterval = setInterval(() => {
            fetchExchangeRates();
        }, 600000);
    }
    
    // ==================== EVENT LISTENERLAR ====================
    function bindEvents() {
        if (convertBtn) {
            convertBtn.addEventListener('click', (e) => {
                e.preventDefault();
                performFullConversion();
            });
        }
        
        if (amountInput) {
            amountInput.addEventListener('keypress', (e) => {
                if (e.key === 'Enter') performFullConversion();
            });
            amountInput.addEventListener('input', () => performFullConversion());
        }
        
        if (currencySelect) {
            currencySelect.addEventListener('change', () => performFullConversion());
        }
        
        if (manualRefreshBtn) {
            manualRefreshBtn.addEventListener('click', () => {
                fetchExchangeRates();
            });
        }
    }
    
    // ==================== INIT ====================
    async function init() {
        bindEvents();
        startAutoRefresh();
        await fetchExchangeRates();  // birinchi yuklash
        performFullConversion();
    }
    
    init();
</script>
</body>
</html>
